# ── Required ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-this-to-a-strong-password

# JWT secret for auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── LLM Provider (at least one required) ──────────────────────────
# Get your API keys from the respective providers
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key
# GOOGLE_API_KEY=your-google-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# XAI_API_KEY=your-xai-api-key

# ── Optional ──────────────────────────────────────────────────────
# Override defaults if needed
# DATABASE_URL=postgresql+psycopg2://advisor:password@postgres:5432/advisor
# REDIS_URL=redis://redis:6379/0
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000

# ── NGINX ─────────────────────────────────────────────────────────
# NGINX_PORT=443
